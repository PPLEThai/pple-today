enum MiniAppTier {
  DRAFT
  BETA
  LIVE
}

enum MiniAppSource {
  ADMIN
  PLATFORM
}

model MiniApp {
  id    String  @id @default(cuid())
  slug  String  @unique
  name  String
  icon  String? // Public icon URL (legacy rows may still hold a base64 data URI)
  order Int     @default(0)

  clientId     String
  clientUrl    String
  requiresAuth Boolean @default(true)

  // Builder-app lifecycle. Existing rows are central-team apps that are already
  // live, so the defaults (LIVE/ADMIN, no owner) keep them behaving exactly as
  // before. Platform-provisioned Builder apps start as DRAFT/PLATFORM with an
  // ownerSub (the Builder's PPLE ID `sub`) so only the owner sees them.
  tier     MiniAppTier   @default(LIVE)
  source   MiniAppSource @default(ADMIN)
  ownerSub String? // Builder's PPLE ID sub; set only when source = PLATFORM

  // Zitadel's internal app id (distinct from the OIDC clientId), recorded when
  // the platform provisions the app so retire can delete the OIDC app. Null for
  // central-team rows, whose Zitadel apps are managed through the admin API.
  zitadelAppId String?

  // Retire is a soft-delete: the platform deletes the Zitadel app and
  // deactivates the notification key, then stamps this. Retired apps are hidden
  // from the mini-app list but the row (and its App User registry) is kept for
  // audit. Null for every live app.
  retiredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  banners Banner[]

  miniAppRoles        MiniAppRole[]
  appUsers            MiniAppUser[]
  notificationApiKeys NotificationApiKey[]
}

// One row per (mini app, user) the first time that user opens the app. Opening
// a mini app for the first time registers the person as that app's App User —
// the consent boundary for audience-bound notifications and the source of the
// Console's per-app user count. Registration is idempotent on the composite
// key: repeat opens touch nothing.
model MiniAppUser {
  miniAppId String
  miniApp   MiniApp @relation(fields: [miniAppId], references: [id])

  userId        String // PPLE ID `sub` of the App User (same identity as User.id)
  user          User     @relation(fields: [userId], references: [id])
  firstOpenedAt DateTime @default(now())

  @@id([miniAppId, userId])
}

model MiniAppRole {
  role String

  miniAppId String
  miniApp   MiniApp @relation(fields: [miniAppId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([role, miniAppId])
}
