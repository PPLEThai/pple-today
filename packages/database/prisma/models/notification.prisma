enum NotificationLinkType {
  MINI_APP
  IN_APP_NAVIGATION
  EXTERNAL_BROWSER
}

model UserNotificationToken {
  token  String @id
  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

enum NotificationInAppType {
  POST
  POLL
  TOPIC
  USER
  ANNOUNCEMENT
  ELECTION
  HASHTAG
  OFFICIAL
  ACTIVITY
  ANNOUNCEMENT_LIST
  NOTIFICATION_LIST
  SEARCH
  PROFILE
  MY_ACTIVITIES
  RECENT_ACTIVITIES
  FOLLOW
  PARTICIPATION
  TOPIC_SUGGESTION
  USER_SUGGESTION
  ELECTION_VOTE
  // Not a navigation entity: marks a notification as a Beta invite so the
  // notification centre renders the accept/decline inbox inline, and a push tap
  // lands on the แอป tab where that same inbox lives.
  MINI_APP_INVITE
}

model Notification {
  id               String                @id @default(cuid())
  title            String
  message          String
  image            String?
  actionButtonText String?
  linkType         NotificationLinkType?
  linkDestination  String?

  linkInAppType NotificationInAppType?
  linkInAppId   String?

  linkBypassNotificationCenter Boolean?

  isBroadcast Boolean  @default(false)
  roles       String[]
  provinces   String[]
  districts   String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentNotifications UserNotification[]
  phoneNumbers      NotificationPhoneNumber[]
}

model NotificationPhoneNumber {
  notificationId String
  phoneNumber    String

  notification Notification @relation(fields: [notificationId], references: [id])

  @@id([notificationId, phoneNumber])
  @@index([phoneNumber])
}

model UserNotification {
  userId         String
  notificationId String

  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  notification Notification @relation(fields: [notificationId], references: [id])

  @@id([userId, notificationId])
  @@index([notificationId])
  @@index([userId])
}

model NotificationApiKey {
  id     String  @id @default(cuid())
  name   String
  apiKey String  @unique
  active Boolean @default(true)

  // App-bound key. Null = legacy central-team key with today's raw
  // phone-number behaviour, unchanged. Set for the per-app key the platform
  // provisions with each Builder App; retire deactivates it via this binding.
  miniAppId String?
  miniApp   MiniApp? @relation(fields: [miniAppId], references: [id])

  // Sends allowed per calendar day (Asia/Bangkok), metered against
  // NotificationApiKeyUsageLog via a transactional claim that locks this row.
  // The default is the Builder App Resource Limit; raises are approved on the
  // platform (LimitRequest) and applied here. Legacy central-team keys are never
  // metered, so this column is inert for them.
  dailyQuota Int @default(1000)

  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt
  usageLogs NotificationApiKeyUsageLog[]

  @@index([active, apiKey])
  @@index([miniAppId])
}

model NotificationApiKeyUsageLog {
  id                   String   @id @default(cuid())
  notificationApiKeyId String
  usedAt               DateTime @default(now())
  body                 Json

  notificationApiKey NotificationApiKey @relation(fields: [notificationApiKeyId], references: [id])

  @@index([notificationApiKeyId])
  @@index([usedAt])
  // Serves the daily-quota count, which always asks "this key, since midnight".
  @@index([notificationApiKeyId, usedAt])
}
